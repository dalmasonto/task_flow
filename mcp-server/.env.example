# MCP server configuration (all optional)

# Server port (default: 3456)
# TASKFLOW_SSE_PORT=3456

# Database path (default: ~/.taskflow/taskflow.db)
# TASKFLOW_DB_PATH=~/.taskflow/taskflow.db

# Bind host (default: 127.0.0.1)
# TASKFLOW_HOST=127.0.0.1

# Log level (default: info)
# TASKFLOW_LOG_LEVEL=info

# ─── Remote relay (optional) ─────────────────────────
# Set these to push events to a relay server for remote access

# Relay server URL
# TASKFLOW_RELAY_URL=https://relay.example.com

# Token for pushing events to the relay
# TASKFLOW_RELAY_PUSH_TOKEN=your-push-token-here
